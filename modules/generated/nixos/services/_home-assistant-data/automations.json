[
  {
    "id": "bedroom_shelly_smart_toggle",
    "alias": "Bedroom Shelly smart toggle",
    "description": "On any state change of the bedroom ceiling input, if lights are off → smart-on (auto level by sun + time); if any are on → smart-off.",
    "triggers": [
      {
        "trigger": "state",
        "entity_id": ["binary_sensor.shelly1minig4_7c2c6773c2f0_input_0_input"],
        "not_from": ["unavailable", "unknown"],
        "not_to": ["unavailable", "unknown"]
      }
    ],
    "conditions": [],
    "actions": [
      {
        "choose": [
          {
            "conditions": [
              {
                "condition": "template",
                "value_template": "{{ states('input_number.bedroom_light_level') | int(0) > 0 }}"
              }
            ],
            "sequence": [
              {"service": "script.bedroom_lights_off"}
            ]
          }
        ],
        "default": [
          {"service": "script.bedroom_lights_smart_on"}
        ]
      }
    ],
    "mode": "single"
  },
  {
    "id": "dimmer_on_press",
    "alias": "Dimmer on press",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_short_press", "subtype": "turn_on"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_short_press", "subtype": "turn_on"}
    ],
    "actions": [{"service": "script.bedroom_lights_smart_on"}],
    "mode": "single"
  },
  {
    "id": "dimmer_off_press",
    "alias": "Dimmer off press",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_short_press", "subtype": "turn_off"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_short_press", "subtype": "turn_off"}
    ],
    "actions": [
      {"service": "script.bedroom_lights_off"}
    ],
    "mode": "single"
  },
  {
    "id": "dimmer_up_short_press",
    "alias": "Dimmer up short press",
    "description": "If lights are off, turn on at one 30% tier above the smart_on level (floor smart_on to tier 0/3/6/10, then +1 tier, cap at L=10). If already on, increment by one step.",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_short_press", "subtype": "dim_up"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_short_press", "subtype": "dim_up"}
    ],
    "actions": [
      {
        "choose": [
          {
            "conditions": [
              {"condition": "template", "value_template": "{{ states('input_number.bedroom_light_level') | int(0) == 0 }}"}
            ],
            "sequence": [
              {
                "service": "input_number.set_value",
                "target": {"entity_id": "input_number.bedroom_light_level"},
                "data": {"value": "{% set e = state_attr('sun.sun','elevation') | float(0) %}{% set h = now().hour %}{% if e > 0 %}{% set s = 10 %}{% elif e > -6 %}{% set s = 7 %}{% elif h >= 23 or h < 6 %}{% set s = 2 %}{% else %}{% set s = 5 %}{% endif %}{% if s >= 6 %}10{% elif s >= 3 %}6{% else %}3{% endif %}"}
              }
            ]
          }
        ],
        "default": [
          {"service": "input_number.increment", "target": {"entity_id": "input_number.bedroom_light_level"}}
        ]
      },
      {"service": "script.apply_bedroom_level", "data": {"transition": 0.3}}
    ],
    "mode": "queued",
    "max": 4
  },
  {
    "id": "dimmer_down_short_press",
    "alias": "Dimmer down short press",
    "description": "If lights are off, turn on at one 30% tier below the smart_on level (ceil smart_on to tier 0/3/6/10, then -1 tier, min L=3). If already on, decrement by one step.",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_short_press", "subtype": "dim_down"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_short_press", "subtype": "dim_down"}
    ],
    "actions": [
      {
        "choose": [
          {
            "conditions": [
              {"condition": "template", "value_template": "{{ states('input_number.bedroom_light_level') | int(0) == 0 }}"}
            ],
            "sequence": [
              {
                "service": "input_number.set_value",
                "target": {"entity_id": "input_number.bedroom_light_level"},
                "data": {"value": "{% set e = state_attr('sun.sun','elevation') | float(0) %}{% set h = now().hour %}{% if e > 0 %}{% set s = 10 %}{% elif e > -6 %}{% set s = 7 %}{% elif h >= 23 or h < 6 %}{% set s = 2 %}{% else %}{% set s = 5 %}{% endif %}{% if s > 6 %}6{% else %}3{% endif %}"}
              }
            ]
          }
        ],
        "default": [
          {"service": "input_number.decrement", "target": {"entity_id": "input_number.bedroom_light_level"}}
        ]
      },
      {"service": "script.apply_bedroom_level", "data": {"transition": 0.3}}
    ],
    "mode": "queued",
    "max": 4
  },
  {
    "id": "dimmer_up_double_press",
    "alias": "Dimmer up double press",
    "description": "Native Hue double-press of brightness UP → snap up to next 30% preset (3=monitor+svetluška, 6=all warm, 10=working).",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_double_press", "subtype": "dim_up"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_double_press", "subtype": "dim_up"}
    ],
    "actions": [
      {
        "service": "input_number.set_value",
        "target": {"entity_id": "input_number.bedroom_light_level"},
        "data": {"value": "{% set L = states('input_number.bedroom_light_level') | int(0) %}{% if L < 3 %}3{% elif L < 6 %}6{% else %}10{% endif %}"}
      },
      {"service": "script.apply_bedroom_level"}
    ],
    "mode": "single"
  },
  {
    "id": "dimmer_down_double_press",
    "alias": "Dimmer down double press",
    "description": "Native Hue double-press of brightness DOWN → snap down to previous 30% preset (6=all warm, 3=monitor+svetluška, 0=off).",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_double_press", "subtype": "dim_down"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_double_press", "subtype": "dim_down"}
    ],
    "actions": [
      {
        "service": "input_number.set_value",
        "target": {"entity_id": "input_number.bedroom_light_level"},
        "data": {"value": "{% set L = states('input_number.bedroom_light_level') | int(0) %}{% if L > 6 %}6{% elif L > 3 %}3{% else %}0{% endif %}"}
      },
      {"service": "script.apply_bedroom_level"}
    ],
    "mode": "single"
  },
  {
    "id": "dimmer_up_long_press_start",
    "alias": "Dimmer up hold",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_long_press", "subtype": "dim_up"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_long_press", "subtype": "dim_up"}
    ],
    "actions": [
      {"service": "input_boolean.turn_on", "target": {"entity_id": "input_boolean.dim_up_holding"}},
      {
        "repeat": {
          "while": [
            {"condition": "state", "entity_id": "input_boolean.dim_up_holding", "state": "on"},
            {"condition": "template", "value_template": "{{ states('input_number.bedroom_light_level') | int(0) < 10 }}"}
          ],
          "sequence": [
            {"service": "input_number.increment", "target": {"entity_id": "input_number.bedroom_light_level"}},
            {"service": "script.apply_bedroom_level", "data": {"transition": 0.15}},
            {"delay": "00:00:00.2"}
          ]
        }
      }
    ],
    "mode": "restart"
  },
  {
    "id": "dimmer_up_long_release",
    "alias": "Dimmer up release",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_long_release", "subtype": "dim_up"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_long_release", "subtype": "dim_up"}
    ],
    "actions": [
      {"service": "input_boolean.turn_off", "target": {"entity_id": "input_boolean.dim_up_holding"}}
    ],
    "mode": "single"
  },
  {
    "id": "dimmer_down_long_press_start",
    "alias": "Dimmer down hold",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_long_press", "subtype": "dim_down"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_long_press", "subtype": "dim_down"}
    ],
    "actions": [
      {"service": "input_boolean.turn_on", "target": {"entity_id": "input_boolean.dim_down_holding"}},
      {
        "repeat": {
          "while": [
            {"condition": "state", "entity_id": "input_boolean.dim_down_holding", "state": "on"},
            {"condition": "template", "value_template": "{{ states('input_number.bedroom_light_level') | int(0) > 0 }}"}
          ],
          "sequence": [
            {"service": "input_number.decrement", "target": {"entity_id": "input_number.bedroom_light_level"}},
            {"service": "script.apply_bedroom_level", "data": {"transition": 0.15}},
            {"delay": "00:00:00.2"}
          ]
        }
      }
    ],
    "mode": "restart"
  },
  {
    "id": "dimmer_down_long_release",
    "alias": "Dimmer down release",
    "triggers": [
      {"trigger": "device", "domain": "zha", "device_id": "7c351f5ca363350e853ee853ae43b6e5", "type": "remote_button_long_release", "subtype": "dim_down"},
      {"trigger": "device", "domain": "zha", "device_id": "3e960c542db95a898624e541ab3f582c", "type": "remote_button_long_release", "subtype": "dim_down"}
    ],
    "actions": [
      {"service": "input_boolean.turn_off", "target": {"entity_id": "input_boolean.dim_down_holding"}}
    ],
    "mode": "single"
  },
  {
    "id": "bedroom_level_apply_on_change",
    "alias": "Bedroom level apply on change",
    "description": "Apply the bedroom light tier whenever input_number.bedroom_light_level changes (e.g. the dashboard slider, which only sets the value). Suppressed during dimmer hold ramps, which apply with their own tuned transition.",
    "triggers": [
      {
        "trigger": "state",
        "entity_id": ["input_number.bedroom_light_level"],
        "not_from": ["unavailable", "unknown"],
        "not_to": ["unavailable", "unknown"]
      }
    ],
    "conditions": [
      {"condition": "state", "entity_id": "input_boolean.dim_up_holding", "state": "off"},
      {"condition": "state", "entity_id": "input_boolean.dim_down_holding", "state": "off"}
    ],
    "actions": [
      {"service": "script.apply_bedroom_level"}
    ],
    "mode": "restart"
  }
]
