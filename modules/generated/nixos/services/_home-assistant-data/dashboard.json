            {
              "type": "custom:mushroom-template-card",
              "primary": "Bedroom",
              "secondary": "{{ states('sensor.bedroom_people') }} · {{ states('sensor.teplomer_loznice_temperature') | float(0) | round(1) }}°C · {{ states('sensor.teplomer_loznice_humidity') | float(0) | round(0) }}% RH",
              "icon": "mdi:bed",
