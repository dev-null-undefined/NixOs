                {
                  "type": "custom:mushroom-template-card",
                  "primary": "Úzdíl",
                  "secondary": "{{ states('sensor.uzdil_room') }}",
                  "icon": "mdi:account",
                  "icon_color": "{{ 'green' if is_state('person.uzdil','home') else 'disabled' }}",
