                  "icon": "mdi:account",
                  "icon_color": "{{ 'green' if is_state('person.martin','home') else 'disabled' }}",
                  "tap_action": {"action": "navigate", "navigation_path": "/lovelace/people#martin"},
                  "entity": "person.martin"
