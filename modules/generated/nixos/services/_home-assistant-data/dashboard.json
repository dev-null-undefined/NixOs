                  "entity": "person.uzdil"
                },
                {
                  "type": "custom:mushroom-template-card",
                  "primary": "Štefánko",
                  "secondary": "{{ states('sensor.stefanko_room') }}",
                  "icon": "mdi:account",
                  "icon_color": "{{ 'green' if is_state('person.stefanko','home') else 'disabled' }}",
