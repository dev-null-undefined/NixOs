                  "entity": "person.stefanko"
                },
                {
                  "type": "custom:mushroom-template-card",
                  "primary": "Samira",
                  "secondary": "{{ states('sensor.samira_room') }}",
                  "icon": "mdi:account",
                  "icon_color": "{{ 'green' if is_state('person.samira','home') else 'disabled' }}",
                  "tap_action": {"action": "navigate", "navigation_path": "/lovelace/people#samira"},
                  "entity": "person.samira"
                }
              ]
            }
          ]
        },
        {
          "type": "grid",
          "cards": [
            {
              "type": "heading",
              "heading": "Rooms now",
              "icon": "mdi:home-floor-1"
            },
            {
              "type": "custom:mushroom-template-card",
              "primary": "Living Room",
              "secondary": "{{ states('sensor.living_room_people') }} · {{ states('sensor.teplomer_living_room_temperature') | float(0) | round(1) }}°C · {{ states('sensor.teplomer_living_room_humidity') | float(0) | round(0) }}% RH",
