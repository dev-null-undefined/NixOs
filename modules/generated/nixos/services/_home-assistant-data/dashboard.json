              "type": "custom:mushroom-template-card",
              "primary": "Martin Bedroom",
              "secondary": "{{ states('sensor.martin_bedroom_people') }}",
              "icon": "mdi:bed-king",
              "icon_color": "{{ 'amber' if states('sensor.martin_bedroom_occupancy') | int > 0 else 'disabled' }}",
